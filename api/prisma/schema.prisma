generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// The single owner of this brain.
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

/// Simple key/value app settings (e.g. the chosen LLM provider+model).
model Setting {
  key   String @id
  value String
}

/// A service connector whose secrets are stored encrypted at rest.
model Connector {
  id        String   @id @default(uuid())
  name      String   @unique // supermemory | rag | notion | telegram | raindrop | anthropic
  secrets   String // AES-256-GCM encrypted JSON
  updatedAt DateTime @updatedAt
}

/// A stored piece of content (research md, bookmark, etc.). Source of truth is the file on disk.
model Item {
  id            String   @id @default(uuid())
  contentHash   String
  source        String // upload | url | notion | raindrop
  title         String?
  summary       String? // short AI/heuristic summary
  sourceUrl     String? // original link for url / notion sources
  filePath      String?
  tags          String? // JSON array of strings
  supermemoryId String?
  ragId         String?
  readFailed    Boolean  @default(false) // bookmark whose page could not be read (summary from metadata only)
  shared        Boolean  @default(false) // publicly viewable via /view/:id when true
  thumbnail     String? // cover image / YouTube thumbnail for bookmark cards
  ideaId        String? // links an uploaded research doc to an Idea
  folderId      String? // bookmark folder (My-Brain-owned, independent of Raindrop) (BEA-611)
  createdAt     DateTime @default(now())

  @@unique([contentHash, source])
  @@index([folderId])
}

/// A My-Brain-owned folder for organising bookmarks (independent of Raindrop). (BEA-611)
model BookmarkFolder {
  id        String   @id @default(uuid())
  name      String
  color     String?
  icon      String? // lucide icon name
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// A captured idea: a brain-dump cleaned up by the LLM, with a /deep-research prompt.
model Idea {
  id             String    @id @default(uuid())
  rawDump        String
  title          String
  content        String
  researchPrompt String
  status         String    @default("open") // open | done
  supermemoryId  String?
  ragId          String?
  createdAt      DateTime  @default(now())
  completedAt    DateTime?
}

/// A saved agentic workflow for an idea (n8n-style): an ordered list of nodes (skills + text steps).
model IdeaWorkflow {
  id           String   @id @default(uuid())
  ideaId       String?  @unique // the idea this flow belongs to (null = a reusable template)
  name         String   @default("Workflow")
  isTemplate   Boolean  @default(false)
  nodes        String   @default("[]") // JSON: [{id,type:'skill'|'text',skill?,text?,config?}]
  customPrompt String? // user-edited Claude Code prompt; null = use the auto-generated one
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// A Claude skill the user tracks (created on Claude Code/Chat, or downloaded).
model Skill {
  id            String    @id @default(uuid())
  title         String
  description   String
  content       String? // the SKILL.md content (pasted/uploaded) — served as the download
  origin        String    @default("created") // created | downloaded
  platform      String    @default("code") // code | chat
  downloadUrl   String? // external link when not app-hosted
  filePath      String? // app-hosted uploaded file (Skills ②)
  slug          String? // skill folder name (auto-scan match)
  source        String? // where it was found (auto-scan)
  deployments   String?   @default("{}") // JSON {targetName: folderSlug} — per-target install tracking (BEA-634)
  inUse         Boolean? // manual using/not-using flag
  installed     Boolean   @default(false) // detected on the server (auto-scan)
  lastUsedAt    DateTime? // from transcripts (auto-scan)
  usageCount    Int       @default(0)
  shared        Boolean   @default(false)
  supermemoryId String?
  ragId         String?
  createdAt     DateTime  @default(now())
}

/// A morning brain-dump: the raw multi-sentence text the LLM turns into tasks.
model BrainDump {
  id        String   @id @default(uuid())
  day       String // local day key YYYY-MM-DD this dump belongs to
  rawText   String
  source    String   @default("app") // app | telegram | voice
  question  String? // a single clarifying question the LLM asked, if any
  taskCount Int      @default(0)
  createdAt DateTime @default(now())
}

/// The mandatory nightly story — the user's free narrative of the day (problems, joy, events).
model Story {
  id              String   @id @default(uuid())
  day             String // local day key YYYY-MM-DD
  rawText         String
  source          String   @default("app") // app | telegram | voice
  mood            String? // optional one-tap mood/energy
  workedMinutes   Int? // user-stated hours worked that day (the real working-hours figure)
  workedBreakdown String? // JSON [{category, minutes}] — AI split of the stated hours across topics
  supermemoryId   String? // Explore index doc ids (so re-index replaces, no dupes)
  ragId           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

/// The AI's end-of-day summary of everything the user did — stored to Activity + RAG/SuperMemory.
model DaySummary {
  id            String   @id @default(uuid())
  day           String   @unique // local day key YYYY-MM-DD
  text          String
  stats         String? // JSON: { tasksDone, tasksOpen, minutesSpent, ... }
  supermemoryId String?
  ragId         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

/// The nightly "Story of the Day" — story + tasks + activity woven into one emotional narrative (11:58 PM).
model DayStory {
  id                String   @id @default(uuid())
  day               String   @unique // local day key YYYY-MM-DD
  text              String // the woven story
  mood              String? // one-word mood read from the day
  moodScore         Int? // 0-100 wellbeing read from the day
  personalText      String? // the personal-life narrative (text = professional when this is set)
  proMoodScore      Int? // 0-100 work mood
  personalMoodScore Int? // 0-100 personal/home mood
  model             String? // which LLM produced it
  supermemoryId     String? // Explore index doc ids (re-index replaces, no dupes)
  ragId             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

/// A predicted task for an upcoming day, proposed by the Story of the Day — the user approves it with "+".
model SuggestedTask {
  id        String   @id @default(uuid())
  forDay    String // local day key YYYY-MM-DD this is suggested FOR (usually tomorrow)
  title     String
  category  String?
  reason    String? // why the Story of the Day suggests it
  status    String   @default("pending") // pending | added | dismissed
  createdAt DateTime @default(now())

  @@index([forDay]) // matches the migration-created index (BEA-828)
}

/// One evidence-grounded read of the user's personality — confirmable in the Validate panel.
model PersonalityInsight {
  id         String   @id @default(uuid())
  generation Int      @default(1) // bumped each regeneration
  dimension  String // e.g. "Follow-through", "Peak hours", "Procrastination"
  claim      String // the honest observation
  evidence   String? // the concrete data it's grounded in
  status     String   @default("pending") // pending | confirmed | rejected
  createdAt  DateTime @default(now())
}

/// One AI request's cost record (feature label + model + tokens + exact OpenRouter cost).
model UsageLog {
  id               String   @id @default(uuid())
  at               DateTime @default(now())
  feature          String // chat | chat-router | task-dump | story-of-day | mentor-guidance | voice-cleanup | …
  model            String
  promptTokens     Int?
  completionTokens Int?
  cost             Float? // USD — exact from OpenRouter; null where the provider doesn't report it

  @@index([at]) // matches the migration-created indexes (BEA-828)
  @@index([feature])
}

/// A quick-capture note (Google Keep style) — LOCAL ONLY, never synced to RAG/SuperMemory.
model Note {
  id            String   @id @default(uuid())
  title         String?
  content       String? // plain-text body
  checklist     String? // JSON array of { text, done } for checklist notes
  color         String   @default("default") // color key, shown as a top strip
  tags          String? // JSON array of strings
  pinned        Boolean  @default(false)
  archived      Boolean  @default(false)
  supermemoryId String? // Explore index doc ids (only set when Notes indexing is enabled)
  ragId         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([archived, pinned]) // matches the migration-created index (BEA-828)
}

/// Per-section index control for Explore: whether a source is indexed + when it last was. (BEA-335)
model IndexSource {
  type          String    @id // task | story | item | idea | meeting | note
  enabled       Boolean   @default(true)
  lastIndexedAt DateTime?
  updatedAt     DateTime  @updatedAt
}

/// A saved Explore answer (question + synthesised answer + its sources). Separate from the index. (BEA-339)
model ExploreSave {
  id        String   @id @default(uuid())
  question  String
  answer    String
  sources   String? // JSON array of the source cards shown with the answer
  createdAt DateTime @default(now())
}

/// A focus area / direction the Mentor tracks — derived from stories or set by the user, then confirmed.
model FocusArea {
  id          String   @id @default(uuid())
  title       String
  description String?
  source      String   @default("derived") // derived | user
  status      String   @default("proposed") // proposed | active | archived
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// One day's Mentor read — how well the day followed the focus areas + the guidance written for it.
model MentorDay {
  id             String   @id @default(uuid())
  day            String   @unique // local day key YYYY-MM-DD
  adherenceScore Int // 0-100: how well the day aligned with the active focus areas
  moodScore      Int? // 0-100 wellbeing carried from the Story of the Day
  guidance       String // the Mentor's direct guidance for the day
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

/// A document in the Documents library — md/html files the user creates to share & re-use.
/// Separate from Item/Capture: NOT indexed into memory unless the user explicitly converts it. (BEA-532)
model Document {
  id            String    @id @default(uuid())
  slug          String    @unique // stable public/url key (editable link name)
  shortCode     String?   @unique // short share code -> /s/:code (BEA-584)
  sharePassword String? // bcrypt hash; when set, the public link asks for a password (BEA-585)
  expiresAt     DateTime? // when set + passed, the public link is treated as un-shared (BEA-585)
  viewCount     Int       @default(0) // public opens of the shared link (BEA-586)
  starred       Boolean   @default(false) // favourited by the owner (BEA-596)
  allowDownload Boolean   @default(false) // let recipients of a shared link download it (BEA-597)
  siteEntry     String? // for kind 'site': entry html path inside the extracted folder (BEA-587)
  title         String
  description   String? // <=200 char summary (manual now; AI-filled later)
  kind          String    @default("md") // md | html | pdf | image | other
  mime          String?
  filename      String?
  contentText   String? // md/html text content (binary files use filePath later)
  filePath      String? // for pdf/images on the volume (later step)
  bytes         Int?
  sourceUrl     String? // when imported from the internet (later step)
  originServer  String? // when landed from another server (later step)
  collectionId  String? // folder/collection (later step)
  tags          String    @default("[]") // JSON string array
  shared        Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([kind])
  @@index([collectionId])
}

/// A folder/collection for grouping documents. (BEA-537)
model DocumentCollection {
  id        String   @id @default(uuid())
  name      String
  color     String?
  icon      String? // lucide icon name for the folder tile (BEA-588)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// The Mentor's Sunday weekly review: the week's wins, drift, one pattern, one experiment.
model WeeklyReview {
  id         String   @id @default(uuid())
  weekStart  String   @unique // Monday of the reviewed week, local YYYY-MM-DD
  text       String // the review prose
  pattern    String? // the ONE pattern the mentor noticed this week
  experiment String? // the ONE experiment proposed for next week
  stats      String? // JSON numbers the review was grounded in
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

/// A month of life woven into one chapter (from the Stories of the Day) — and the building block of the year book.
model MonthStory {
  id            String   @id @default(uuid())
  month         String   @unique // YYYY-MM
  title         String? // chapter title
  text          String
  supermemoryId String? // Explore index doc ids (re-index replaces, no dupes)
  ragId         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

/// The Story of the Year — the book itself, woven from the monthly chapters (Dec 31 + on-demand "year so far").
model YearStory {
  id            String   @id @default(uuid())
  year          String   @unique // YYYY
  title         String?
  text          String
  partial       Boolean  @default(false) // true = a "year so far" draft, rewritten as months land
  supermemoryId String? // Explore index doc ids (re-index replaces, no dupes)
  ragId         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

/// One person mentioned in the user's own story on one day (people memory; aggregated per person in code).
model PersonMention {
  id        String   @id @default(uuid())
  name      String // canonical display name
  day       String // local day key
  createdAt DateTime @default(now())

  @@unique([name, day])
}

/// A sealed day — once a DayClose row exists for a day, that day is finalized (story/mood/mentor are final, leftovers have rolled forward). Absence = the day is still open.
model DayClose {
  id       String   @id @default(uuid())
  day      String   @unique // local day key YYYY-MM-DD
  auto     Boolean  @default(false) // true = auto-sealed after the grace window, false = user closed it
  closedAt DateTime @default(now())
}

/// A quick note the user speaks/types during the day (daytime oral capture).
model DayNote {
  id        String   @id @default(uuid())
  day       String // local day key YYYY-MM-DD
  text      String
  source    String   @default("app") // app | telegram | voice
  createdAt DateTime @default(now())
}

/// A task in the daily loop.
model Task {
  id            String    @id @default(uuid())
  title         String
  note          String?
  category      String? // AI-learned bucket (Beakn, Learning, Admin, Health…)
  tags          String? // JSON array of strings
  priority      String    @default("medium") // high | medium | low
  sphere        String    @default("work") // work | personal — which life this task belongs to
  pinned        Boolean   @default(false) // a top 1–3 must-do for the day
  estimateMin   Int? // AI time estimate in minutes
  actualMin     Int? // user-reported actual time on completion
  reminderCount Int       @default(0) // how many reminders the user wants
  reminders     String? // JSON array of ISO datetimes (AI-scheduled)
  day           String? // local day key YYYY-MM-DD this task is planned for
  dumpId        String? // the BrainDump this task was extracted from
  party         String? // who this task is a promise TO / with — folded in from Commitments (BEA-604)
  reminderSuggestDismissed Boolean @default(false) // user cleared this from "Suggested reminders" (BEA-882)
  dueDate       DateTime?
  status        String    @default("open") // open | done
  progress      Int       @default(0) // 0 | 30 | 60 | 100 — how far along (100 = done)
  followUp      Boolean   @default(false) // true if this task was spawned as a follow-up to another
  rolloverCount Int       @default(0)
  supermemoryId String? // Explore index doc ids (so re-index replaces, no dupes)
  ragId         String?
  createdAt     DateTime  @default(now())
  completedAt   DateTime?
}

/// Outbox: every memory write is queued here, then a worker drains it to both stores with retries.
model MemoryOutbox {
  id        String   @id @default(uuid())
  itemId    String? // the ref row's id (named itemId for back-compat); refType says which table
  refType   String? // item (default/null) | task | story | idea | meeting — which table to write the doc id back to
  target    String // supermemory | rag
  op        String   @default("upsert")
  payload   String // JSON
  status    String   @default("pending") // pending | done | failed
  attempts  Int      @default(0)
  lastError String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Generic polling/sync cursor (e.g. id="raindrop").
model SyncState {
  id        String   @id
  cursor    String?
  updatedAt DateTime @updatedAt
}

/// A chat conversation with the assistant ("talk to my brain"), scoped to one memory tag.
model ChatSession {
  id            String    @id @default(uuid())
  title         String?
  scope         String    @default("everything") // everything | bookmark | idea | activity | document | skill
  docId         String? // set = a per-document chat bound to this Item (answers only from that doc)
  summary       String? // rolling summary of older turns (keeps long threads cheap)
  pinned        Boolean   @default(false) // protected from retention auto-clean
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())
}

/// One message in a chat thread.
model ChatMessage {
  id        String   @id @default(uuid())
  sessionId String
  role      String // user | assistant
  content   String
  sources   String? // JSON array of {title, url?, itemId?}
  followups String? // JSON array of suggested next questions
  starred   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([sessionId])
}

/// A starred message — a preserved copy that is NEVER auto-deleted by retention.
model ChatStar {
  id           String   @id @default(uuid())
  messageId    String   @unique
  sessionId    String?
  sessionTitle String?
  scope        String   @default("everything")
  role         String
  content      String
  sources      String?
  createdAt    DateTime @default(now())
}

/// Audit log of every action the agent takes.
model AgentActionLog {
  id        String   @id @default(uuid())
  sessionId String?
  tool      String
  args      String? // JSON
  result    String?
  createdAt DateTime @default(now())
}

/// A configured agent the user can run (flagship Agent feature). Runs on Hermes; My Brain is the shell.
model Agent {
  id           String     @id @default(uuid())
  name         String
  icon         String? // emoji
  description  String?
  prompt       String? // the task template the agent runs (the scheduled/run-now instruction)
  rubric       String? // the Outcome — the definition of done each run is graded against (BEA-641)
  evals        String     @default("[]") // JSON [{id,input,lastVerdict,lastScore,lastRunId,lastRunAt}] — regression cases (BEA-642)
  autonomy     String     @default("cautious") // cautious | balanced | autopilot
  skills       String     @default("[]") // JSON string array of skill ids/names
  schedule     String? // JSON { every: day|weekday|week|hour, at?: "HH:MM", dow?: 0-6 }; null = manual only
  scheduleText String? // human sentence ("every weekday 7am")
  lastFiredKey String? // "<dayKey>:<HH:MM>" of the last scheduled fire — dedup so a schedule fires once
  outputDest   String     @default("document") // document | telegram | task
  defaultDepth String     @default("standard") // quick | standard | deep — default run depth (BEA-695)
  collectionId String? // Documents collection for saved outputs
  enabled      Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  runs         AgentRun[]
}

/// One execution of an agent. Mirrors a Hermes session and carries our durable HITL state.
model AgentRun {
  id          String      @id @default(uuid())
  agentId     String?
  agent       Agent?      @relation(fields: [agentId], references: [id], onDelete: SetNull)
  depth       String? // quick | standard | deep — the depth this run used (BEA-695)
  title       String?
  status      String      @default("running") // running | awaiting_input | scheduled | done | failed | cancelled
  input       String? // the prompt/topic (JSON or text)
  sessionId   String? // Hermes session id (the bridge fills this in BEA-618)
  stepLog     String      @default("[]") // JSON array of step records (mirror of Hermes events)
  learnings   String      @default("[]") // JSON [{text,status:proposed|kept|forgotten,memId?}] — what the run learned (BEA-624)
  outputDocId String? // saved Document id
  resultText  String? // the agent's final answer text, shown inline on the run (BEA-630)
  grade       String? // JSON grade vs the agent's Outcome rubric {verdict,score,criteria,notes} (BEA-641)
  error       String?
  startedAt   DateTime    @default(now())
  endedAt     DateTime?
  waitpoints  Waitpoint[]

  @@index([agentId])
  @@index([status])
}

/// A DURABLE human-in-the-loop pause: the run asks a question and waits — survives an API/host restart. The piece Hermes lacks.
model Waitpoint {
  id           String    @id @default(uuid())
  runId        String
  run          AgentRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  question     String
  kind         String    @default("choice") // choice | free_text | approve_edit_reject | form
  options      String    @default("[]") // JSON: choices, or form fields, or the draft for approve_edit_reject
  defaultValue String? // smart default applied on timeout
  status       String    @default("pending") // pending | answered | expired | cancelled
  answer       String? // JSON of the user's answer
  resumeToken  String    @unique
  answeredVia  String? // telegram | web
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  answeredAt   DateTime?

  @@index([runId])
  @@index([status])
}

/// One day's Gmail "Daily Brief": unread count + an AI summary of that day's important emails.
/// Generated nightly (11:58 PM local) and on first open; keyed by local day so history is instant.
model GmailBrief {
  day           String   @id // YYYY-MM-DD in the user's timezone
  unread        Int      @default(0)
  summary       String   @default("")
  sections      String? // JSON array of {heading, points[], link} accordion topic cards
  items         String? // JSON array of {from, subject, time} important emails
  model         String?
  supermemoryId String? // Explore index doc ids (mandatory section)
  ragId         String?
  generatedAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

/// A saved "Gmail request": a natural-language email search turned into an AI briefing of one thread.
/// Frozen snapshot (Refresh re-runs it). Optionally shared via a public link, saved to memory, etc.
model GmailRequest {
  id            String   @id @default(uuid())
  query         String // the natural-language ask
  title         String // auto-titled from the query; user-renamable
  threadId      String? // the chosen Gmail thread
  threadSubject String?
  summary       String   @default("") // AI description + key points (markdown)
  emailCopy     String? // the relevant email copy used to build the summary
  shared        Boolean  @default(false)
  shareId       String?  @unique // public token for the share link
  itemId        String? // set if imported to Capture
  supermemoryId String? // Explore index doc ids (mandatory section)
  ragId         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

/// A recorded meeting. Audio is captured first; transcription + AI summary are opt-in (ticket B).
model Meeting {
  id            String   @id @default(uuid())
  title         String   @default("Untitled meeting")
  agenda        String? // optional pre-meeting notes the AI considers
  audioPath     String? // stored recording on the data volume
  audioMime     String? // e.g. audio/webm
  durationSec   Int      @default(0)
  status        String   @default("recorded") // recorded | transcribing | transcribed
  engine        String? // which transcription engine was used
  transcript    String?
  summary       String?
  takeaways     String? // JSON array of strings
  decisions     String? // JSON array of strings
  actionItems   String? // JSON array of {title, ...}
  language      String?
  tags          String? // JSON array of AI keywords
  savedToMemory Boolean  @default(false)
  supermemoryId String?
  ragId         String?
  shared        Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

/// A commitment the owner made ("I'll send X by Friday") — extracted from the day. (BEA-355)
model Commitment {
  id          String    @id @default(uuid())
  text        String
  party       String? // who it's to / with
  dueDate     String? // YYYY-MM-DD if stated
  status      String    @default("open") // open | done | dropped
  source      String    @default("story") // story | task | meeting | summary
  sourceDay   String // the day it was extracted from
  confirmed   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  completedAt DateTime?
}

/// A decision that was made ("we're going with the rust design") — extracted from the day. (BEA-355)
model Decision {
  id        String   @id @default(uuid())
  text      String
  context   String?
  source    String   @default("story")
  sourceDay String
  createdAt DateTime @default(now())
}

/// A proactive connection the brain surfaced on its own (cross-type related items). (BEA-357)
model Connection {
  id        String   @id @default(uuid())
  summary   String
  items     String // JSON [{type, id, title, link}]
  score     Float    @default(0)
  status    String   @default("new") // new | seen | dismissed
  anchorKey String // type:id of the anchor, for dedup
  createdAt DateTime @default(now())
}

/// Vault metadata — the zero-knowledge crypto envelope. Server stores ONLY ciphertext
/// + wrapped keys; never the passphrase, never a raw key, never a plaintext secret. (BEA-345)
model VaultMeta {
  id           String   @id @default(uuid())
  kdfParams    String // JSON: Argon2id memory/iterations/parallelism/hashLength
  salt         String // base64
  verifier     String // JSON {iv,ct}: a known constant encrypted by the vault key
  wrapPass     String // JSON {iv,ct}: vault key wrapped by the passphrase-derived master key
  wrapRecovery String // JSON {iv,ct}: vault key wrapped by the recovery key
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// One encrypted vault item. `blob` is the envelope-encrypted secret (ciphertext only).
/// The other columns are SEARCHABLE METADATA only — never a secret value. (BEA-345)
model VaultItem {
  id            String   @id @default(uuid())
  type          String // login | apisecret | card | bank | crypto | identity | document | note | license | wifi | membership
  blob          String // JSON EncryptedBlob {v, item:{iv,ct}, dataKey:{iv,ct}}
  title         String? // searchable
  website       String? // searchable
  username      String? // searchable
  tags          String? // searchable (comma-separated)
  cardType      String? // searchable (e.g. "Visa")
  bankName      String? // searchable
  collection    String? // Personal | Work | Beakn | Family
  favorite      Boolean  @default(false)
  // Pointers to the LABEL-ONLY index docs (BEA-368). Store-doc ids only — never a secret. Lets an
  // edit replace its indexed metadata and a delete remove it. The encrypted `blob` is NEVER indexed.
  supermemoryId String?
  ragId         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([type]) // matches the migration-created indexes (BEA-828)
  @@index([collection])
}

/// A device whose biometric/passkey (WebAuthn PRF) can unlock the vault. Stores ONLY the vault key
/// wrapped by the device's PRF-derived secret — never the key itself, never a biometric. (BEA-352)
model VaultDevice {
  id           String   @id @default(uuid())
  credentialId String   @unique // base64url WebAuthn credential id
  label        String
  wrap         String // JSON {iv,ct}: vault key wrapped by the device's PRF secret
  createdAt    DateTime @default(now())
}

/// Per-item audit trail — records WHEN an action happened (revealed/edited/copied/created), never the
/// value. Lets the owner see access history. (BEA-353)
model VaultAudit {
  id     String   @id @default(uuid())
  itemId String
  action String // created | edited | revealed | copied
  at     DateTime @default(now())

  @@index([itemId]) // matches the migration-created index (BEA-828)
}

/// One important email stored in memory (BEA-439). PK = Gmail message id so re-sync upserts (no dupes).
/// Full body is indexed into RAG + SuperMemory for whole-brain recall. supermemoryId/ragId are the
/// index doc pointers (replace-on-edit), never the secret.
model EmailMemory {
  id            String    @id // Gmail message id
  threadId      String
  fromAddr      String
  subject       String
  day           String // YYYY-MM-DD the email belongs to
  sentAt        DateTime?
  snippet       String?
  body          String? // full plain-text body
  supermemoryId String?
  ragId         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([day])
}

/// "The Lab" — the mini mental model (BEA-446). One MindFinding = one hypothesis/edge about the user,
/// learned from tasks (done/postponed/skipped) + stories + activity + ideas. It lives: reinforced by
/// recurrence, decays when evidence dries up (by its own cadence), confirmed/refuted by the user.
model MindFinding {
  id            String   @id @default(uuid())
  statement     String // human-readable hypothesis, e.g. "Money/deep-work tasks tend to drain you"
  kind          String // emotional | behavioural | relational | temporal | causal
  subject       String // the "from" node, e.g. "money tasks"
  relation      String // e.g. drains | energizes | precedes | avoids | co-occurs
  object        String // the "to" node, e.g. "you" / "anxiety"
  valence       String   @default("neutral") // energizing | draining | neutral
  confidence    Float    @default(0.2) // 0–1
  evidenceCount Int      @default(1) // n
  status        String   @default("proposed") // proposed | emerging | established | fading | retired
  cadence       String? // daily | weekly | situational | null
  trend         String   @default("rising") // rising | steady | fading
  validated     String? // null | confirmed | refuted  (user ✓/✗)
  pinned        Boolean  @default(false) // never decays
  firstSeenDay  String // YYYY-MM-DD
  lastSeenDay   String // YYYY-MM-DD
  supermemoryId String? // dual-store index pointers
  ragId         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  evidence MindEvidence[]

  @@index([status])
}

/// A concrete piece of evidence behind a MindFinding — the task/story/activity/idea that supports it.
model MindEvidence {
  id         String      @id @default(uuid())
  findingId  String
  finding    MindFinding @relation(fields: [findingId], references: [id], onDelete: Cascade)
  sourceType String // task | story | activity | idea
  sourceId   String?
  day        String // YYYY-MM-DD
  signal     String // done | postponed | skipped | told | created
  snippet    String?
  createdAt  DateTime    @default(now())

  @@index([findingId])
}

// A plain run-log so the user can see WHEN automatic work ran (date + time). (BEA-468)
model MindRun {
  id     String   @id @default(uuid())
  at     DateTime @default(now())
  kind   String // learn | wrap
  day    String? // the day it concerns (YYYY-MM-DD)
  detail String

  @@index([at])
}

// The Situation model (BEA-515): your real chains — a GOAL, what's BLOCKING it, and the LEVER that unblocks it.
// e.g. goal "Get Beakn products out" / blocker "production not aligned" / lever "fix the production line first".
model MindChain {
  id           String   @id @default(uuid())
  goal         String
  blocker      String
  lever        String
  note         String?
  provenance   String? // where this came from: "From your 25 Jun story · deferred: X" (BEA-543)
  source       String // user | engine
  status       String   @default("active") // active | resolved | retired
  confidence   Float    @default(0.7)
  validated    String? // confirmed | refuted
  pinned       Boolean  @default(false)
  shifted      Boolean  @default(false) // engine re-derived this chain on day-close (ToC "repeat"); cleared when the user confirms/edits (BEA-526)
  firstSeenDay String?
  lastSeenDay  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status])
}

/// A visual flow (Phase 2 / n8n-style canvas, BEA-644). graph = React Flow {nodes, edges} JSON.
model Flow {
  id           String   @id @default(uuid())
  name         String   @default("Untitled flow")
  question     String? // the entry question the flow answers
  agentId      String? // the agent this flow was generated from (Agent↔Flow merge)
  graph        String   @default("{\"nodes\":[],\"edges\":[]}")
  schedule     String? // JSON Sched {every, at, dow} — when set, runs on a timer (Stage 3)
  lastFiredKey String? // dedup key so a schedule fires once per slot
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// One execution of a Flow (BEA-646). results = JSON {nodeId: {status, output, kind, label}}.
model FlowRun {
  id           String    @id @default(uuid())
  flowId       String?
  status       String    @default("running") // running | done | failed
  results      String    @default("{}")
  finalOutput  String?
  documentIds  String    @default("[]") // documents this run produced: JSON [{id, slug, title}]
  terminal     String    @default("[]") // live play-by-play: JSON [{text, at}]
  error        String?
  waitNodeId   String? // Move B: the "Ask me" node the run is paused on
  waitQuestion String? // the question shown to the user
  waitKind     String? // free_text | choice
  waitOptions  String    @default("[]") // JSON array of choices
  waitToken    String? // opaque resume token
  startedAt    DateTime  @default(now())
  endedAt      DateTime?
}

/// A person you can send WhatsApp reminders to (BEA-719).
model Contact {
  id             String     @id @default(uuid())
  name           String
  whatsappNumber String? // E.164 digits incl. country code; null until you add one
  notes          String?
  tags           String     @default("[]") // JSON string array
  aliases        String     @default("[]") // JSON array of other spellings/names for this same person (BEA-763)
  lastReadAt     DateTime? // when the owner last opened this contact's chat — powers unread badges (BEA-922)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  reminders      Reminder[]

  @@index([name])
}

/// A WhatsApp reminder to chase a contact about a task (BEA-720).
model Reminder {
  id           String            @id @default(uuid())
  contactId    String
  contact      Contact           @relation(fields: [contactId], references: [id], onDelete: Cascade)
  taskId       String? // the Task this chases (status stays the user's to close)
  subject      String? // short "what you're chasing" for the template {{2}} (task title if linked)
  message      String // the free-text we send in the 24h window (in the user's voice)
  notes        String? // standing context Sandeep adds; fed into the agent's replies (BEA-765)
  count        Int               @default(1) // how many times today (1-5)
  times        String            @default("[]") // JSON array of ISO datetimes to send at
  status       String            @default("active") // active | done | stopped
  feedback     String? // captured result once the contact says it's done
  lastFiredKey String? // dedup key for the daily scheduler
  armedDay     String? // local day (YYYY-MM-DD) this reminder was armed/seeded for — one-day lifecycle (BEA-764)
  pausedAuto   Boolean           @default(false) // true when auto-paused at day rollover (vs paused by the user)
  needsOwner   Boolean           @default(false) // agent couldn't answer → flagged for Sandeep to reply (BEA-766)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  sends        ReminderSend[]
  messages     ReminderMessage[]

  @@index([contactId])
  @@index([status])
}

/// One scheduled send of a reminder (BEA-720). Fired by the outbound scheduler in P4.
model ReminderSend {
  id         String   @id @default(uuid())
  reminderId String
  reminder   Reminder @relation(fields: [reminderId], references: [id], onDelete: Cascade)
  at         DateTime
  status     String   @default("queued") // queued | sending (claimed, BEA-775) | sent | delivered | read | failed | skipped
  providerId String? // the BSP (Postbox/WhatsApp) message id once sent
  error      String? // friendly error if the send failed
  createdAt  DateTime @default(now())

  @@index([reminderId])
  @@index([status])
}

/// The WhatsApp conversation for a reminder: our outbound nudges + the contact's replies.
/// C1 records these; the two-way agent (C2) reads/acts on them.
model ReminderMessage {
  id         String    @id @default(uuid())
  contactId  String? // the conversation this belongs to (one per contact) — BEA-742
  reminderId String? // the reminder that triggered it (a combined nudge covers several)
  reminder   Reminder? @relation(fields: [reminderId], references: [id], onDelete: SetNull)
  direction  String // out | in
  body       String
  wamid      String?
  status     String? // out: sent | delivered | read | failed (WhatsApp receipts, BEA-916); in: null
  error      String? // provider error when status=failed
  createdAt  DateTime  @default(now())

  @@index([contactId])
  @@index([reminderId])
  @@index([wamid])
}

/// A third-party OAuth client that registered (Dynamic Client Registration) to reach the public MCP. (BEA-758)
model OAuthClient {
  id           String   @id // the client_id
  secret       String? // optional; public clients (Claude) use PKCE with no secret
  name         String?
  redirectUris String // JSON array of allowed redirect URIs
  createdAt    DateTime @default(now())
}

/// A short-lived authorization code (PKCE) issued after the owner approves an OAuth client. (BEA-758)
model OAuthCode {
  code          String   @id
  clientId      String
  redirectUri   String
  codeChallenge String // S256 challenge; verified against the verifier at the token endpoint
  scope         String?
  userId        String
  used          Boolean  @default(false)
  expiresAt     DateTime
  createdAt     DateTime @default(now())

  @@index([clientId])
}

/// EMO (BEA-861) — a "receipt" card for every voice capture. Deliberately THIN: it carries the raw
/// recording + transcript + a one-line summary of what Emo did, and LINKS to the real object
/// (task/reminder/flow/meeting/document) which stays the single source of truth. The "answer-later"
/// clarify (Needs-you HITL) lives ON the card. Named EmoCard so it never collides with UI "cards"
/// (which are Items). Design: /home/sandy/emo-behavior-design.md
model EmoCard {
  id            String   @id @default(uuid())
  lane          String // search | story | reminder | task | meeting | research | note | talk
  status        String   @default("cooking") // done | cooking | needs_you
  title         String?
  summary       String? // one-line "what Emo did" — readable without opening the link
  detail        String? // markdown body (curated findings, meeting summary, …)
  links         String   @default("[]") // JSON [{kind,id,label}] pointers to the real objects
  sources       String   @default("[]") // JSON [{n,title,link,when,snippet,sourceType,source}] cited sources
  needsQuestion String? // the clarify question shown on the card (durable Needs-you HITL)
  needsOptions  String   @default("[]") // JSON array of suggested answers (optional)
  needsAnswer   String? // the owner's answer once given
  source        String   @default("emo") // where the capture came from
  day           String // IST day key YYYY-MM-DD — powers the "Today's Captures" grouping
  rawTranscript String?
  audioPath     String? // the raw recording file (part of the receipt)
  error         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([day])
  @@index([status])
  @@index([lane])
}
