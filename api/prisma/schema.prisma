generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// The single owner of this brain.
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

/// Simple key/value app settings (e.g. the chosen LLM provider+model).
model Setting {
  key   String @id
  value String
}

/// A service connector whose secrets are stored encrypted at rest.
model Connector {
  id        String   @id @default(uuid())
  name      String   @unique // supermemory | rag | notion | telegram | raindrop | anthropic
  secrets   String // AES-256-GCM encrypted JSON
  updatedAt DateTime @updatedAt
}

/// A stored piece of content (research md, bookmark, etc.). Source of truth is the file on disk.
model Item {
  id            String   @id @default(uuid())
  contentHash   String
  source        String // upload | url | notion | raindrop
  title         String?
  summary       String? // short AI/heuristic summary
  sourceUrl     String? // original link for url / notion sources
  filePath      String?
  tags          String? // JSON array of strings
  supermemoryId String?
  ragId         String?
  readFailed    Boolean  @default(false) // bookmark whose page could not be read (summary from metadata only)
  shared        Boolean  @default(false) // publicly viewable via /view/:id when true
  thumbnail     String? // cover image / YouTube thumbnail for bookmark cards
  ideaId        String? // links an uploaded research doc to an Idea
  createdAt     DateTime @default(now())

  @@unique([contentHash, source])
}

/// A captured idea: a brain-dump cleaned up by the LLM, with a /deep-research prompt.
model Idea {
  id             String    @id @default(uuid())
  rawDump        String
  title          String
  content        String
  researchPrompt String
  status         String    @default("open") // open | done
  supermemoryId  String?
  ragId          String?
  createdAt      DateTime  @default(now())
  completedAt    DateTime?
}

/// A Claude skill the user tracks (created on Claude Code/Chat, or downloaded).
model Skill {
  id            String    @id @default(uuid())
  title         String
  description   String
  content       String? // the SKILL.md content (pasted/uploaded) — served as the download
  origin        String    @default("created") // created | downloaded
  platform      String    @default("code") // code | chat
  downloadUrl   String? // external link when not app-hosted
  filePath      String? // app-hosted uploaded file (Skills ②)
  slug          String? // skill folder name (auto-scan match)
  source        String? // where it was found (auto-scan)
  inUse         Boolean? // manual using/not-using flag
  installed     Boolean   @default(false) // detected on the server (auto-scan)
  lastUsedAt    DateTime? // from transcripts (auto-scan)
  usageCount    Int       @default(0)
  shared        Boolean   @default(false)
  supermemoryId String?
  ragId         String?
  createdAt     DateTime  @default(now())
}

/// A morning brain-dump: the raw multi-sentence text the LLM turns into tasks.
model BrainDump {
  id          String   @id @default(uuid())
  day         String // local day key YYYY-MM-DD this dump belongs to
  rawText     String
  source      String   @default("app") // app | telegram | voice
  question    String? // a single clarifying question the LLM asked, if any
  taskCount   Int      @default(0)
  createdAt   DateTime @default(now())
}

/// The mandatory nightly story — the user's free narrative of the day (problems, joy, events).
model Story {
  id        String   @id @default(uuid())
  day       String // local day key YYYY-MM-DD
  rawText   String
  source    String   @default("app") // app | telegram | voice
  mood      String? // optional one-tap mood/energy
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// The AI's end-of-day summary of everything the user did — stored to Activity + RAG/SuperMemory.
model DaySummary {
  id            String   @id @default(uuid())
  day           String   @unique // local day key YYYY-MM-DD
  text          String
  stats         String? // JSON: { tasksDone, tasksOpen, minutesSpent, ... }
  supermemoryId String?
  ragId         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

/// A quick note the user speaks/types during the day (daytime oral capture).
model DayNote {
  id        String   @id @default(uuid())
  day       String // local day key YYYY-MM-DD
  text      String
  source    String   @default("app") // app | telegram | voice
  createdAt DateTime @default(now())
}

/// A task in the daily loop.
model Task {
  id            String    @id @default(uuid())
  title         String
  note          String?
  category      String? // AI-learned bucket (Beakn, Learning, Admin, Health…)
  tags          String? // JSON array of strings
  priority      String    @default("medium") // high | medium | low
  pinned        Boolean   @default(false) // a top 1–3 must-do for the day
  estimateMin   Int? // AI time estimate in minutes
  actualMin     Int? // user-reported actual time on completion
  reminderCount Int       @default(0) // how many reminders the user wants
  reminders     String? // JSON array of ISO datetimes (AI-scheduled)
  day           String? // local day key YYYY-MM-DD this task is planned for
  dumpId        String? // the BrainDump this task was extracted from
  dueDate       DateTime?
  status        String    @default("open") // open | done
  rolloverCount Int       @default(0)
  createdAt     DateTime  @default(now())
  completedAt   DateTime?
}

/// Outbox: every memory write is queued here, then a worker drains it to both stores with retries.
model MemoryOutbox {
  id        String   @id @default(uuid())
  itemId    String?
  target    String // supermemory | rag
  op        String   @default("upsert")
  payload   String // JSON
  status    String   @default("pending") // pending | done | failed
  attempts  Int      @default(0)
  lastError String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Generic polling/sync cursor (e.g. id="raindrop").
model SyncState {
  id        String   @id
  cursor    String?
  updatedAt DateTime @updatedAt
}

/// A chat conversation with the assistant.
model ChatSession {
  id        String   @id @default(uuid())
  title     String?
  createdAt DateTime @default(now())
}

/// Audit log of every action the agent takes.
model AgentActionLog {
  id        String   @id @default(uuid())
  sessionId String?
  tool      String
  args      String? // JSON
  result    String?
  createdAt DateTime @default(now())
}
