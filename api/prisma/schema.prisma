generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// The single owner of this brain.
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

/// Simple key/value app settings (e.g. the chosen LLM provider+model).
model Setting {
  key   String @id
  value String
}

/// A service connector whose secrets are stored encrypted at rest.
model Connector {
  id        String   @id @default(uuid())
  name      String   @unique // supermemory | rag | notion | telegram | raindrop | anthropic
  secrets   String // AES-256-GCM encrypted JSON
  updatedAt DateTime @updatedAt
}

/// A stored piece of content (research md, bookmark, etc.). Source of truth is the file on disk.
model Item {
  id            String   @id @default(uuid())
  contentHash   String
  source        String // upload | url | notion | raindrop
  title         String?
  summary       String? // short AI/heuristic summary
  sourceUrl     String? // original link for url / notion sources
  filePath      String?
  tags          String? // JSON array of strings
  supermemoryId String?
  ragId         String?
  readFailed    Boolean  @default(false) // bookmark whose page could not be read (summary from metadata only)
  shared        Boolean  @default(false) // publicly viewable via /view/:id when true
  thumbnail     String? // cover image / YouTube thumbnail for bookmark cards
  ideaId        String? // links an uploaded research doc to an Idea
  createdAt     DateTime @default(now())

  @@unique([contentHash, source])
}

/// A captured idea: a brain-dump cleaned up by the LLM, with a /deep-research prompt.
model Idea {
  id             String    @id @default(uuid())
  rawDump        String
  title          String
  content        String
  researchPrompt String
  status         String    @default("open") // open | done
  supermemoryId  String?
  ragId          String?
  createdAt      DateTime  @default(now())
  completedAt    DateTime?
}

/// A saved agentic workflow for an idea (n8n-style): an ordered list of nodes (skills + text steps).
model IdeaWorkflow {
  id           String   @id @default(uuid())
  ideaId       String?  @unique // the idea this flow belongs to (null = a reusable template)
  name         String   @default("Workflow")
  isTemplate   Boolean  @default(false)
  nodes        String   @default("[]") // JSON: [{id,type:'skill'|'text',skill?,text?,config?}]
  customPrompt String? // user-edited Claude Code prompt; null = use the auto-generated one
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// A Claude skill the user tracks (created on Claude Code/Chat, or downloaded).
model Skill {
  id            String    @id @default(uuid())
  title         String
  description   String
  content       String? // the SKILL.md content (pasted/uploaded) — served as the download
  origin        String    @default("created") // created | downloaded
  platform      String    @default("code") // code | chat
  downloadUrl   String? // external link when not app-hosted
  filePath      String? // app-hosted uploaded file (Skills ②)
  slug          String? // skill folder name (auto-scan match)
  source        String? // where it was found (auto-scan)
  inUse         Boolean? // manual using/not-using flag
  installed     Boolean   @default(false) // detected on the server (auto-scan)
  lastUsedAt    DateTime? // from transcripts (auto-scan)
  usageCount    Int       @default(0)
  shared        Boolean   @default(false)
  supermemoryId String?
  ragId         String?
  createdAt     DateTime  @default(now())
}

/// A morning brain-dump: the raw multi-sentence text the LLM turns into tasks.
model BrainDump {
  id        String   @id @default(uuid())
  day       String // local day key YYYY-MM-DD this dump belongs to
  rawText   String
  source    String   @default("app") // app | telegram | voice
  question  String? // a single clarifying question the LLM asked, if any
  taskCount Int      @default(0)
  createdAt DateTime @default(now())
}

/// The mandatory nightly story — the user's free narrative of the day (problems, joy, events).
model Story {
  id            String   @id @default(uuid())
  day           String // local day key YYYY-MM-DD
  rawText       String
  source        String   @default("app") // app | telegram | voice
  mood          String? // optional one-tap mood/energy
  workedMinutes Int? // user-stated hours worked that day (the real working-hours figure)
  workedBreakdown String? // JSON [{category, minutes}] — AI split of the stated hours across topics
  supermemoryId String? // Explore index doc ids (so re-index replaces, no dupes)
  ragId         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

/// The AI's end-of-day summary of everything the user did — stored to Activity + RAG/SuperMemory.
model DaySummary {
  id            String   @id @default(uuid())
  day           String   @unique // local day key YYYY-MM-DD
  text          String
  stats         String? // JSON: { tasksDone, tasksOpen, minutesSpent, ... }
  supermemoryId String?
  ragId         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

/// The nightly "Story of the Day" — story + tasks + activity woven into one emotional narrative (11:58 PM).
model DayStory {
  id                String   @id @default(uuid())
  day               String   @unique // local day key YYYY-MM-DD
  text              String // the woven story
  mood              String? // one-word mood read from the day
  moodScore         Int? // 0-100 wellbeing read from the day
  personalText      String? // the personal-life narrative (text = professional when this is set)
  proMoodScore      Int? // 0-100 work mood
  personalMoodScore Int? // 0-100 personal/home mood
  model             String? // which LLM produced it
  supermemoryId     String? // Explore index doc ids (re-index replaces, no dupes)
  ragId             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

/// A predicted task for an upcoming day, proposed by the Story of the Day — the user approves it with "+".
model SuggestedTask {
  id        String   @id @default(uuid())
  forDay    String // local day key YYYY-MM-DD this is suggested FOR (usually tomorrow)
  title     String
  category  String?
  reason    String? // why the Story of the Day suggests it
  status    String   @default("pending") // pending | added | dismissed
  createdAt DateTime @default(now())
}

/// One evidence-grounded read of the user's personality — confirmable in the Validate panel.
model PersonalityInsight {
  id         String   @id @default(uuid())
  generation Int      @default(1) // bumped each regeneration
  dimension  String // e.g. "Follow-through", "Peak hours", "Procrastination"
  claim      String // the honest observation
  evidence   String? // the concrete data it's grounded in
  status     String   @default("pending") // pending | confirmed | rejected
  createdAt  DateTime @default(now())
}

/// One AI request's cost record (feature label + model + tokens + exact OpenRouter cost).
model UsageLog {
  id               String   @id @default(uuid())
  at               DateTime @default(now())
  feature          String // chat | chat-router | task-dump | story-of-day | mentor-guidance | voice-cleanup | …
  model            String
  promptTokens     Int?
  completionTokens Int?
  cost             Float? // USD — exact from OpenRouter; null where the provider doesn't report it
}

/// A quick-capture note (Google Keep style) — LOCAL ONLY, never synced to RAG/SuperMemory.
model Note {
  id        String   @id @default(uuid())
  title     String?
  content   String? // plain-text body
  checklist String? // JSON array of { text, done } for checklist notes
  color     String   @default("default") // color key, shown as a top strip
  tags      String? // JSON array of strings
  pinned    Boolean  @default(false)
  archived  Boolean  @default(false)
  supermemoryId String? // Explore index doc ids (only set when Notes indexing is enabled)
  ragId         String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Per-section index control for Explore: whether a source is indexed + when it last was. (BEA-335)
model IndexSource {
  type          String   @id // task | story | item | idea | meeting | note
  enabled       Boolean  @default(true)
  lastIndexedAt DateTime?
  updatedAt     DateTime @updatedAt
}

/// A saved Explore answer (question + synthesised answer + its sources). Separate from the index. (BEA-339)
model ExploreSave {
  id        String   @id @default(uuid())
  question  String
  answer    String
  sources   String? // JSON array of the source cards shown with the answer
  createdAt DateTime @default(now())
}

/// A focus area / direction the Mentor tracks — derived from stories or set by the user, then confirmed.
model FocusArea {
  id          String   @id @default(uuid())
  title       String
  description String?
  source      String   @default("derived") // derived | user
  status      String   @default("proposed") // proposed | active | archived
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// One day's Mentor read — how well the day followed the focus areas + the guidance written for it.
model MentorDay {
  id             String   @id @default(uuid())
  day            String   @unique // local day key YYYY-MM-DD
  adherenceScore Int // 0-100: how well the day aligned with the active focus areas
  moodScore      Int? // 0-100 wellbeing carried from the Story of the Day
  guidance       String // the Mentor's direct guidance for the day
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

/// The Mentor's Sunday weekly review: the week's wins, drift, one pattern, one experiment.
model WeeklyReview {
  id         String   @id @default(uuid())
  weekStart  String   @unique // Monday of the reviewed week, local YYYY-MM-DD
  text       String // the review prose
  pattern    String? // the ONE pattern the mentor noticed this week
  experiment String? // the ONE experiment proposed for next week
  stats      String? // JSON numbers the review was grounded in
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

/// A month of life woven into one chapter (from the Stories of the Day) — and the building block of the year book.
model MonthStory {
  id        String   @id @default(uuid())
  month     String   @unique // YYYY-MM
  title     String? // chapter title
  text      String
  supermemoryId String? // Explore index doc ids (re-index replaces, no dupes)
  ragId         String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// The Story of the Year — the book itself, woven from the monthly chapters (Dec 31 + on-demand "year so far").
model YearStory {
  id        String   @id @default(uuid())
  year      String   @unique // YYYY
  title     String?
  text      String
  partial   Boolean  @default(false) // true = a "year so far" draft, rewritten as months land
  supermemoryId String? // Explore index doc ids (re-index replaces, no dupes)
  ragId         String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// One person mentioned in the user's own story on one day (people memory; aggregated per person in code).
model PersonMention {
  id        String   @id @default(uuid())
  name      String // canonical display name
  day       String // local day key
  createdAt DateTime @default(now())

  @@unique([name, day])
}

/// A sealed day — once a DayClose row exists for a day, that day is finalized (story/mood/mentor are final, leftovers have rolled forward). Absence = the day is still open.
model DayClose {
  id       String   @id @default(uuid())
  day      String   @unique // local day key YYYY-MM-DD
  auto     Boolean  @default(false) // true = auto-sealed after the grace window, false = user closed it
  closedAt DateTime @default(now())
}

/// A quick note the user speaks/types during the day (daytime oral capture).
model DayNote {
  id        String   @id @default(uuid())
  day       String // local day key YYYY-MM-DD
  text      String
  source    String   @default("app") // app | telegram | voice
  createdAt DateTime @default(now())
}

/// A task in the daily loop.
model Task {
  id            String    @id @default(uuid())
  title         String
  note          String?
  category      String? // AI-learned bucket (Beakn, Learning, Admin, Health…)
  tags          String? // JSON array of strings
  priority      String    @default("medium") // high | medium | low
  sphere        String    @default("work") // work | personal — which life this task belongs to
  pinned        Boolean   @default(false) // a top 1–3 must-do for the day
  estimateMin   Int? // AI time estimate in minutes
  actualMin     Int? // user-reported actual time on completion
  reminderCount Int       @default(0) // how many reminders the user wants
  reminders     String? // JSON array of ISO datetimes (AI-scheduled)
  day           String? // local day key YYYY-MM-DD this task is planned for
  dumpId        String? // the BrainDump this task was extracted from
  dueDate       DateTime?
  status        String    @default("open") // open | done
  progress      Int       @default(0) // 0 | 30 | 60 | 100 — how far along (100 = done)
  followUp      Boolean   @default(false) // true if this task was spawned as a follow-up to another
  rolloverCount Int       @default(0)
  supermemoryId String? // Explore index doc ids (so re-index replaces, no dupes)
  ragId         String?
  createdAt     DateTime  @default(now())
  completedAt   DateTime?
}

/// Outbox: every memory write is queued here, then a worker drains it to both stores with retries.
model MemoryOutbox {
  id        String   @id @default(uuid())
  itemId    String? // the ref row's id (named itemId for back-compat); refType says which table
  refType   String? // item (default/null) | task | story | idea | meeting — which table to write the doc id back to
  target    String // supermemory | rag
  op        String   @default("upsert")
  payload   String // JSON
  status    String   @default("pending") // pending | done | failed
  attempts  Int      @default(0)
  lastError String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Generic polling/sync cursor (e.g. id="raindrop").
model SyncState {
  id        String   @id
  cursor    String?
  updatedAt DateTime @updatedAt
}

/// A chat conversation with the assistant ("talk to my brain"), scoped to one memory tag.
model ChatSession {
  id            String    @id @default(uuid())
  title         String?
  scope         String    @default("everything") // everything | bookmark | idea | activity | document | skill
  docId         String? // set = a per-document chat bound to this Item (answers only from that doc)
  summary       String? // rolling summary of older turns (keeps long threads cheap)
  pinned        Boolean   @default(false) // protected from retention auto-clean
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())
}

/// One message in a chat thread.
model ChatMessage {
  id        String   @id @default(uuid())
  sessionId String
  role      String // user | assistant
  content   String
  sources   String? // JSON array of {title, url?, itemId?}
  followups String? // JSON array of suggested next questions
  starred   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([sessionId])
}

/// A starred message — a preserved copy that is NEVER auto-deleted by retention.
model ChatStar {
  id           String   @id @default(uuid())
  messageId    String   @unique
  sessionId    String?
  sessionTitle String?
  scope        String   @default("everything")
  role         String
  content      String
  sources      String?
  createdAt    DateTime @default(now())
}

/// Audit log of every action the agent takes.
model AgentActionLog {
  id        String   @id @default(uuid())
  sessionId String?
  tool      String
  args      String? // JSON
  result    String?
  createdAt DateTime @default(now())
}

/// One day's Gmail "Daily Brief": unread count + an AI summary of that day's important emails.
/// Generated nightly (11:58 PM local) and on first open; keyed by local day so history is instant.
model GmailBrief {
  day         String   @id // YYYY-MM-DD in the user's timezone
  unread      Int      @default(0)
  summary     String   @default("")
  sections    String? // JSON array of {heading, points[], link} accordion topic cards
  items       String? // JSON array of {from, subject, time} important emails
  model       String?
  supermemoryId String? // Explore index doc ids (mandatory section)
  ragId         String?
  generatedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// A saved "Gmail request": a natural-language email search turned into an AI briefing of one thread.
/// Frozen snapshot (Refresh re-runs it). Optionally shared via a public link, saved to memory, etc.
model GmailRequest {
  id            String   @id @default(uuid())
  query         String // the natural-language ask
  title         String // auto-titled from the query; user-renamable
  threadId      String? // the chosen Gmail thread
  threadSubject String?
  summary       String   @default("") // AI description + key points (markdown)
  emailCopy     String? // the relevant email copy used to build the summary
  shared        Boolean  @default(false)
  shareId       String?  @unique // public token for the share link
  itemId        String? // set if imported to Capture
  supermemoryId String? // Explore index doc ids (mandatory section)
  ragId         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

/// A recorded meeting. Audio is captured first; transcription + AI summary are opt-in (ticket B).
model Meeting {
  id            String    @id @default(uuid())
  title         String    @default("Untitled meeting")
  agenda        String? // optional pre-meeting notes the AI considers
  audioPath     String? // stored recording on the data volume
  audioMime     String? // e.g. audio/webm
  durationSec   Int       @default(0)
  status        String    @default("recorded") // recorded | transcribing | transcribed
  engine        String? // which transcription engine was used
  transcript    String?
  summary       String?
  takeaways     String? // JSON array of strings
  decisions     String? // JSON array of strings
  actionItems   String? // JSON array of {title, ...}
  language      String?
  tags          String? // JSON array of AI keywords
  savedToMemory Boolean   @default(false)
  supermemoryId String?
  ragId         String?
  shared        Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

/// A commitment the owner made ("I'll send X by Friday") — extracted from the day. (BEA-355)
model Commitment {
  id          String    @id @default(uuid())
  text        String
  party       String? // who it's to / with
  dueDate     String? // YYYY-MM-DD if stated
  status      String    @default("open") // open | done | dropped
  source      String    @default("story") // story | task | meeting | summary
  sourceDay   String // the day it was extracted from
  confirmed   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  completedAt DateTime?
}

/// A decision that was made ("we're going with the rust design") — extracted from the day. (BEA-355)
model Decision {
  id        String   @id @default(uuid())
  text      String
  context   String?
  source    String   @default("story")
  sourceDay String
  createdAt DateTime @default(now())
}

/// A proactive connection the brain surfaced on its own (cross-type related items). (BEA-357)
model Connection {
  id        String   @id @default(uuid())
  summary   String
  items     String // JSON [{type, id, title, link}]
  score     Float    @default(0)
  status    String   @default("new") // new | seen | dismissed
  anchorKey String // type:id of the anchor, for dedup
  createdAt DateTime @default(now())
}

/// Vault metadata — the zero-knowledge crypto envelope. Server stores ONLY ciphertext
/// + wrapped keys; never the passphrase, never a raw key, never a plaintext secret. (BEA-345)
model VaultMeta {
  id           String   @id @default(uuid())
  kdfParams    String // JSON: Argon2id memory/iterations/parallelism/hashLength
  salt         String // base64
  verifier     String // JSON {iv,ct}: a known constant encrypted by the vault key
  wrapPass     String // JSON {iv,ct}: vault key wrapped by the passphrase-derived master key
  wrapRecovery String // JSON {iv,ct}: vault key wrapped by the recovery key
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// One encrypted vault item. `blob` is the envelope-encrypted secret (ciphertext only).
/// The other columns are SEARCHABLE METADATA only — never a secret value. (BEA-345)
model VaultItem {
  id         String   @id @default(uuid())
  type       String // login | apisecret | card | bank | crypto | identity | document | note | license | wifi | membership
  blob       String // JSON EncryptedBlob {v, item:{iv,ct}, dataKey:{iv,ct}}
  title      String? // searchable
  website    String? // searchable
  username   String? // searchable
  tags       String? // searchable (comma-separated)
  cardType   String? // searchable (e.g. "Visa")
  bankName   String? // searchable
  collection String? // Personal | Work | Beakn | Family
  favorite   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

/// A device whose biometric/passkey (WebAuthn PRF) can unlock the vault. Stores ONLY the vault key
/// wrapped by the device's PRF-derived secret — never the key itself, never a biometric. (BEA-352)
model VaultDevice {
  id           String   @id @default(uuid())
  credentialId String   @unique // base64url WebAuthn credential id
  label        String
  wrap         String // JSON {iv,ct}: vault key wrapped by the device's PRF secret
  createdAt    DateTime @default(now())
}
