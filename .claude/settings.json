{
  "worktree": { "bgIsolation": "none" },
  "permissions": {
    "allow": [
      "Bash(git *)", "Bash(gh *)", "Bash(npm *)", "Bash(npx *)", "Bash(pnpm *)",
      "Bash(node *)", "Bash(docker *)", "Bash(.claude/checks/*)", "Edit", "Write"
    ],
    "deny": ["Read(./.env)", "Read(./.env.*)", "Read(./secrets/**)"]
  },
  "hooks": {
    "PreToolUse": [
      { "matcher": "Bash", "hooks": [ { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/checks/guard.sh" } ] }
    ],
    "PostToolUse": [
      { "matcher": "Edit|Write", "hooks": [ { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/checks/format.sh" } ] }
    ],
    "Stop": [
      { "hooks": [ { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/checks/verify.sh" } ] }
    ]
  }
}
